# Clave de API de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Modelo a usar
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Contraseña del dashboard (la que usás para entrar a la app)
DASHBOARD_PASSWORD=tu-contraseña-secreta

# Secreto de sesión — poné cualquier string largo y aleatorio
SESSION_SECRET=cambia-esto-por-un-string-largo-y-aleatorio
